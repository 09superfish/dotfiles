{
  // Waybar placement and size
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 10,

  "modules-left": [
    "custom/logo",
    "hyprland/workspaces",       // Workspace indicators (Hyprland)
    "custom/media",
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
      "tray",
      "cpu",
      "network",
      "battery",
      "pulseaudio",
      "clock",
      //"date",
      "custom/power"
    ],

    "hyprland/workspaces": {
        "on-click": "activate",
        "format": "{id}",
        "format-icons": {
            "default": "о©±",
            //"active": "у±“»",
            "urgent": "у±“»"
        },
    },

    "tray": {
        "spacing": 10
    },

  "clock": {
      "format": "{:%H:%M, %a, %d / %B / %Y}",       // Time + day + month abbrev + year
      "tooltip": false
  },
  "cpu": {
      "format": "п’ј  {usage}%",
      "interval": 1,
      "on-click": "kitty -e btop"
  },

  "custom/logo": {
      "format": "вЂў",
      "tooltip": false,
      "on-click": "firefox 'http://kaischakel.nl'"
  },

  // Network module
  "network": {
      "format-wifi": "у°–©  {signalStrength}%",
      "tooltip-format-wifi": "ssid: {essid}",
      "format-ethernet": "ој‰ој‰у°›іој‰ој‰ој‰",
      "tooltip-format-ethernet": "{ifname} via {gwaddr} у°±“",
      "format-linked": "у°Ђ‘",
      "format-disconnected": "у°–Є",
      "tooltip-format-disconnected": "Disconnected",
      "format-alt": "{ipaddr}/{cidr} ({ifname})",
  },

  // Battery module
  "battery": {
    "states": {
        "good": 85,
        "warning": 30,
        "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% п‡¦",
    "format-plugged": "{capacity}% п‡¦",
    "format-alt": "{time} {icon}",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
    "format-bluetooth-muted": "о»Ё {icon}пЉ” {format_source}",
    "format-muted": "{volume}% о»Ё {format_source}",
    "format-source": "{volume}% п„°",
    "format-source": "",
    "format-source-muted": "п„±",
      "format-icons": {
        "headphone": "пЂҐ",
        "default": ["пЂ¦", "пЂ§", "пЂЁ"]
    },
    "on-click": "pavucontrol-qt"
  },

  "custom/power": {
    "format" : "вЏ»",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
    "menu-actions": {
      "shutdown": "systemctl poweroff",
      "reboot": "systemctl reboot",
      "lock": "hyprlock",
    }
  },

  // рџЋµ Media module (MPRIS-based)
  // - Auto-hides when nothing is playing
  // - Shows song + artist
  // - Scroll to skip, click to play/pause
  // - Tooltip shows album art + progress bar
  "custom/media": {
      "format": "{}",
      "return-type": "json",
      "exec": "/home/kai/.config/waybar/scripts/media.sh",
      "interval": 1,
      "on-click": "playerctl play-pause",
      "on-scroll-up": "/home/kai/.config/waybar/scripts/media_control.sh next",
      "on-scroll-down": "/home/kai/.config/waybar/scripts/media_control.sh previous"
  }
}
